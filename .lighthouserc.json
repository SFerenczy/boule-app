{
	"ci": {
		"collect": {
			"staticDistDir": "./build",
			"url": ["http://localhost/index.html"],
			"numberOfRuns": 3,
			"settings": {
				"formFactor": "mobile",
				"screenEmulation": {
					"mobile": true,
					"width": 375,
					"height": 667,
					"deviceScaleFactor": 2,
					"disabled": false
				},
				"throttling": {
					"cpuSlowdownMultiplier": 4,
					"downloadThroughputKbps": 1600,
					"uploadThroughputKbps": 750,
					"rttMs": 150
				}
			}
		},
		"assert": {
			"assertions": {
				"categories:performance": ["error", { "minScore": 0.9, "aggregationMethod": "median" }],
				"categories:accessibility": ["error", { "minScore": 0.85, "aggregationMethod": "median" }],
				"categories:best-practices": ["error", { "minScore": 0.9, "aggregationMethod": "median" }],
				"categories:seo": ["error", { "minScore": 0.8, "aggregationMethod": "median" }]
			}
		},
		"upload": {
			"target": "filesystem",
			"outputDir": ".lighthouseci"
		}
	}
}
